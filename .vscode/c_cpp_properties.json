{
    "configurations": [
        {
      "name": "macOS (Apple Silicon Homebrew)",
      "intelliSenseMode": "macos-clang-arm64",
      "compilerPath": "/usr/bin/clang++",
      "cppStandard": "c++17",
      "cStandard": "c17",
      "includePath": [
        "${workspaceFolder}",
        "${workspaceFolder}/src",
        "${workspaceFolder}/src/imgui",
        "/opt/homebrew/opt/sfml/include",
        "/opt/homebrew/include"
      ],
      "macFrameworkPath": [
        "/System/Library/Frameworks",
        "/Library/Frameworks"
      ]
    },
    {
      "name": "macOS (Intel Homebrew)",
      "intelliSenseMode": "macos-clang-x64",
      "compilerPath": "/usr/bin/clang++",
      "cppStandard": "c++17",
      "cStandard": "c17",
      "includePath": [
        "${workspaceFolder}/**",
        "/usr/local/include"
      ],
      "macFrameworkPath": [
        "/System/Library/Frameworks",
        "/Library/Frameworks"
      ]
    },
    {
      "name": "Linux",
      "intelliSenseMode": "linux-gcc-x64",
      "compilerPath": "/usr/bin/g++",
      "cppStandard": "c++17",
      "cStandard": "c17",
      "includePath": [
        "${workspaceFolder}/**",
        "/usr/include"
      ]
    }
    ],
    "version": 4
    
}